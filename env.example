# FinLagX Environment Configuration

# =============================================================================
# TIMESCALEDB CONFIGURATION
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finlagx
DB_USER=postgres
DB_PASSWORD=finlagx_password

# =============================================================================
# MLFLOW CONFIGURATION  
# =============================================================================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_BACKEND_STORE_URI=postgresql://postgres:finlagx_password@localhost:5432/${MLFLOW_DB:-mlflow}
MLFLOW_ARTIFACT_ROOT=./mlruns

# =============================================================================
# API KEYS
# =============================================================================
# FRED API (Federal Reserve Economic Data)
# Get your key from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

